# ── Pi Server ─────────────────────────────────────────────────────────────────
# The public URL of your Pi (IP or DDNS hostname + port)
# Example: http://123.45.67.89:3001  or  http://mypi.ddns.net:3001
PI_SERVER_URL=http://YOUR_PUBLIC_IP:3001

# Must match the API_KEY in your pi-server/.env
PI_API_KEY=change_me_to_a_long_random_secret

# ── App ───────────────────────────────────────────────────────────────────────
# Your Vercel deployment URL (no trailing slash)
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
